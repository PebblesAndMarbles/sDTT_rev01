# Core Python cache/build artifacts
__pycache__/
*.py[cod]

# VS Code local metadata
.vscode/

# Runtime and generated outputs (large/ephemeral)
integrated_output/*.csv
integrated_output/query_files/
logs/
flag_images/
**/integrated_output/
**/logs/
**/flag_images/

# Keep repository code-first: ignore data/log artifacts by extension
*.csv
*.xlsx
*.log

# Keep 1280KARC targeting CSVs versioned while leaving heavy outputs ignored
!adaptations/1280KARC/prod_targeting/
!adaptations/1280KARC/prod_targeting/*.csv

# Ignore any debug folder contents
debug/
**/debug/

# Generated local helper output
prod_targeting/workflow

# First push scope: exclude legacy archive folder
Old/

# OS and misc local artifacts
Thumbs.db
.DS_Store
