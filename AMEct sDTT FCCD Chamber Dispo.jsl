);

// ============================================================
// APPLY_TARGET_REGIME_FILTER
// Retains only rows in the most recent continuous target regime
// for each PROD_MOP_PILOT group.
// Requires: PROD_MOP_PILOT, DATA_COLLECTION_TIME, ALLSTATS_MEAN_TARGET_VALUE
// ============================================================
Apply_Target_Regime_Filter = Function( {dt},
    dt << Sort(
        By( :PROD_MOP_PILOT, :DATA_COLLECTION_TIME ),
        Order( Ascending, Ascending ),
        Replace Table,
        Output Table( "" )
    );

    If( Try( Column( dt, "TARGET_GROUP_KEY" ); 1, 0 ) == 0,
        dt << New Column( "TARGET_GROUP_KEY", Character, Formula( Char( :PROD_MOP_PILOT ) ) );
    ,
        Column( dt, "TARGET_GROUP_KEY" ) << Delete Formula;
        Column( dt, "TARGET_GROUP_KEY" ) << Set Each Value( Char( :PROD_MOP_PILOT ) );
    );

    If( Try( Column( dt, "TARGET_REGIME_LATEST" ); 1, 0 ) == 0,
        dt << New Column( "TARGET_REGIME_LATEST", Numeric, Continuous, Format( "Best", 8 ), Set Each Value( 0 ) );
    ,
        Column( dt, "TARGET_REGIME_LATEST" ) << Delete Formula;
        Column( dt, "TARGET_REGIME_LATEST" ) << Set Each Value( 0 );
    );

    unique_keys = Associative Array( dt:TARGET_GROUP_KEY ) << Get Keys;
    Debug_Trace( "Target regime filter: groups=" || Char( N Items( unique_keys ) ) );

    For( k = 1, k <= N Items( unique_keys ), k++,
        gkey = unique_keys[k];
        rows = dt << Get Rows Where( :TARGET_GROUP_KEY == gkey );
        If( N Items( rows ) == 0, Continue() );

        n = N Items( rows );
        last_row = rows[n];
        last_tgt = Num( dt:ALLSTATS_MEAN_TARGET_VALUE[last_row] );

        If( Is Missing( last_tgt ),
            For( j = 1, j <= n, j++,
                dt:TARGET_REGIME_LATEST[rows[j]] = 1;
            );
            Debug_Trace( "REGIME " || gkey || " | last target missing, kept all " || Char( n ) || " rows" );
            Continue();
        );

        regime_start = n;
        While( regime_start > 1,
            prev_tgt = Num( dt:ALLSTATS_MEAN_TARGET_VALUE[rows[regime_start - 1]] );
            If( Is Missing( prev_tgt ) | prev_tgt != last_tgt,
                Break();
            );
            regime_start = regime_start - 1;
        );

        For( j = regime_start, j <= n, j++,
            dt:TARGET_REGIME_LATEST[rows[j]] = 1;
        );

        Debug_Trace(
            "REGIME " || gkey ||
            " | last target=" || Char( last_tgt ) ||
            " | kept=" || Char( n - regime_start + 1 ) ||
            " | dropped=" || Char( regime_start - 1 )
        );
    );

    before_rows = N Rows( dt );
    dt << Select Where( :TARGET_REGIME_LATEST != 1 );
    dt << Delete Rows;
    dt << Clear Select;
    Debug_Trace( "Target regime filter complete. Before=" || Char( before_rows ) || " | After=" || Char( N Rows( dt ) ) );
    dt;
);

Normalize_Report_List = Function( {report_obj},
    If( Is List( report_obj ),
        Return( report_obj );
    );
    {report_obj};
);

Resolve_Copy_Target = Function( {rpt},
    copy_target = .;
    Try( copy_target = rpt[OutlineBox(1)] );
    If( !Is Scriptable( copy_target ), Try( copy_target = rpt[OutlineBox(2)] ) );
    If( !Is Scriptable( copy_target ), Try( copy_target = rpt[ListBox(2)] ) );
    If( !Is Scriptable( copy_target ), Try( copy_target = rpt[FrameBox(1)] ) );
    copy_target;
);

Resolve_Live_Report_From_Platform = Function( {platform_obj, layer_key = ""},
    live_rpt = .;
    rpt_obj = .;
    Try( rpt_obj = platform_obj << Report );
    rpt_list = Normalize_Report_List( rpt_obj );
    If( N Items( rpt_list ) <= 0,
        Return( live_rpt );
    );
    target_layer = Uppercase( Trim( Char( layer_key ) ) );
    If( target_layer != "",
        // Pass 1: title contains target layer key (handles post-format renamed titles)
        For( i = 1, i <= N Items( rpt_list ), i++,
            rpt_candidate = rpt_list[i];
            candidate_title = "";
            Try( candidate_title = Uppercase( Char( rpt_candidate << Get Title ) ) );
            If( Contains( candidate_title, target_layer ) > 0,
                live_rpt = rpt_candidate;
                Break();
            );
        );
    );
    If( !Is Scriptable( live_rpt ),
        Try( live_rpt = rpt_list[1] );
    );
    live_rpt;
);

Append_Copy_Button = Function({config, layer_name, button_label, source_platform, source_rpt, debug_tag, panel_key = "MEAN"},
    use_sigma_panel = Uppercase( Char( panel_key ) ) == "SIGMA";

    If( use_sigma_panel,
        copy_button_list = config["copy_button_list_sigma"];
        If( !Is Scriptable( copy_button_list ),
            copy_button_list = copy_button_list_sigma_runtime;
        );
        copy_layer_boxes = copy_layer_boxes_sigma_runtime;
        copy_layer_label_boxes = copy_layer_label_boxes_sigma_runtime;
        layer_padding = copy_layer_extra_padding + 24;
    ,
        copy_button_list = config["copy_button_list_mean"];
        If( !Is Scriptable( copy_button_list ),
            copy_button_list = copy_button_list_mean_runtime;
        );
        copy_layer_boxes = copy_layer_boxes_mean_runtime;
        copy_layer_label_boxes = copy_layer_label_boxes_mean_runtime;
        layer_padding = copy_layer_extra_padding;
    );

    If( !Is Scriptable( copy_button_list ),
        Return();
    );

    If( !Is Scriptable( copy_layer_boxes ),
        copy_layer_boxes = Associative Array();
    );
    If( !Is Scriptable( copy_layer_label_boxes ),
        copy_layer_label_boxes = Associative Array();
    );

    If( use_sigma_panel,
        copy_layer_boxes_sigma_runtime = copy_layer_boxes;
        copy_layer_label_boxes_sigma_runtime = copy_layer_label_boxes;
    ,
        copy_layer_boxes_mean_runtime = copy_layer_boxes;
        copy_layer_label_boxes_mean_runtime = copy_layer_label_boxes;
    );

    layer_key = Uppercase( Trim( Char( layer_name ) ) );
    layer_keys = copy_layer_boxes << Get Keys;

    If( !Contains( layer_keys, layer_key ),
        layer_button_box = V List Box();
        layer_container_box = V List Box(
            layer_button_box,
            Spacer Box( Size( 1, layer_padding ) )
        );
        copy_button_list << Append(
            Outline Box( layer_key, layer_container_box )
        );
        copy_layer_boxes[layer_key] = layer_button_box;
    );

    layer_button_box = copy_layer_boxes[layer_key];
    If( !Contains( copy_layer_label_boxes << Get Keys, layer_key ),
        copy_layer_label_boxes[layer_key] = Associative Array();
    );
    layer_labels = copy_layer_label_boxes[layer_key];
    label_key = Uppercase( Trim( Char( button_label ) ) );
    If( Contains( layer_labels << Get Keys, label_key ),
        If( use_sigma_panel,
            copy_layer_boxes_sigma_runtime = copy_layer_boxes;
            copy_layer_label_boxes_sigma_runtime = copy_layer_label_boxes;
        ,
            copy_layer_boxes_mean_runtime = copy_layer_boxes;
            copy_layer_label_boxes_mean_runtime = copy_layer_label_boxes;
        );
        Return();
    );
    layer_labels[label_key] = 1;
    Eval(
        Eval Expr(
            Expr( layer_button_box ) << Append(
                Button Box( Expr( button_label ),
                    copy_status = "unknown";
                    source_rpt_live = .;
                    live_rpt = .;
                    click_target = .;
                    Try(
                        source_rpt_live = Expr( source_rpt );
                    );
                    If( Is Scriptable( source_rpt_live ),
                        Try( click_target = Resolve_Copy_Target( source_rpt_live ) );
                    );
                    If( !Is Scriptable( click_target ),
                        Try( live_rpt = Resolve_Live_Report_From_Platform( Expr( source_platform ), Expr( layer_key ) ) );
                        If( Is Scriptable( live_rpt ),
                            Try( click_target = Resolve_Copy_Target( live_rpt ) );
                        );
                    );
                    If( Is Scriptable( click_target ),
                        Try(
                            click_target << Copy Picture;
                            copy_status = "copied";
                        ,
                            copy_status = "copy_error_skipped";
                        );
                    ,
                        copy_status = "no_scriptable_target";
                    );
                    If( copy_pic_debug == 1,
                        Print( "COPY DEBUG [" || Expr( debug_tag ) || "] layer=" || Expr( layer_key ) || " button=" || Expr( button_label ) || " copy_status=" || copy_status || " src_rpt=" || Char( Is Scriptable( source_rpt_live ) ) || " live_rpt=" || Char( Is Scriptable( live_rpt ) ) );
                    );
                )
            )
        )
    );

    // Persist per-panel layer/group state so later calls append to the same layer outline.
    If( use_sigma_panel,
        copy_layer_boxes_sigma_runtime = copy_layer_boxes;
        copy_layer_label_boxes_sigma_runtime = copy_layer_label_boxes;
    ,
        copy_layer_boxes_mean_runtime = copy_layer_boxes;
        copy_layer_label_boxes_mean_runtime = copy_layer_label_boxes;
    );
);

// ============================================================
// FORMATTING FUNCTIONS
// ============================================================
Format_Trend_Charts = Function({trend_chart_object, type, config},
    // Extract values from config associative array
    recent_limits_mdttucl = config["recent_limits_mdttucl"];
    recent_limits_mdttcl = config["recent_limits_mdttcl"];
    recent_limits_mdttlcl = config["recent_limits_mdttlcl"];
    recent_limits_sdttucl = config["recent_limits_sdttucl"];
    recent_limits_sdttcl = config["recent_limits_sdttcl"];
    recent_limits_sdttlcl = config["recent_limits_sdttlcl"];
    legendcol1 = config["legendcol1"];
    //legendcol2 = config["legendcol2"];
    UCL_COLOR = config["UCL_COLOR"];
    CL_COLOR = config["CL_COLOR"];
    LCL_COLOR = config["LCL_COLOR"];
    ucl_label = config["ucl_label"];
    cl_label = config["cl_label"];
    lcl_label = config["lcl_label"];
    yinc = config["yinc"];
    tinc = config["tinc"];
    val_show_splines = config["show_splines"];
    tech_str = config["tech_str"];
    dataset_title_str = config["dataset_title_str"];
    If( Is Missing( dataset_title_str ) | dataset_title_str == "",
        dataset_title_str = tech_str;
    );
    dataset_title_str = config["dataset_title_str"];
    If( Is Missing( dataset_title_str ) | dataset_title_str == "",
        dataset_title_str = tech_str;
    );
    time_axis_min = config["time_axis_min"];
    time_axis_max = config["time_axis_max"];
    no_limits = Try( config["no_limits"], 0 );

    Treports = trend_chart_object << Report;
    j=0;
    // Lazy-build layer → TEST_NAME map (shared via config; pre-built here so Trend titles resolve before Variability Charts run)
    If( !Is Associative Array( Try( config["layer_to_testname"], . ) ),
        _lttn = Associative Array();
        _bycol = Try( config["bycol1"], "" );
        _dt_ref = Try( config["dt"], Current Data Table() );
        If( Is Scriptable( _dt_ref ) & _bycol != "",
            Try(
                _lk_col = Column( _dt_ref, _bycol );
                _tn_col = Column( _dt_ref, "TEST_NAME" );
                _nr = N Rows( _dt_ref );
                For( _i = 1, _i <= _nr, _i++,
                    _lk = Uppercase( Trim( Char( _lk_col[_i] ) ) );
                    _tn = Trim( Char( _tn_col[_i] ) );
                    If( _lk != "" & _tn != "",
                        _lttn[_lk] = _tn;
                    );
                );
            );
        );
        config["layer_to_testname"] = _lttn;
    );
    
    If(type=="ALL",
        rpt=Treports;
//        rpt[Frame Box(1)] << Row Legend(:TEST_NAME, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:APC_PRODGROUP, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:PRODUCT_GROUP, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:ALLSTATS_STANDARD_FLAG, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:STATISTICS_MEAN_DTT_STANDARD_FLAG, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:STATISTICS_MEAN_DTT_VIOLATED_RULE_NOTATION, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:STATISTICS_SIGMA_DTT_STANDARD_FLAG, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:STATISTICS_SIGMA_DTT_VIOLATED_RULE_NOTATION, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));		
//        rpt[Frame Box(1)] << Row Legend(:SCANNER, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:ROUTE_TYPE, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:LOT_TYPE, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:IS_POR, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:APC_FB_SUC, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:APC_AREA, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));
//        rpt[Frame Box(1)] << Row Legend(:SPC_PILOT_NAME, Color(0), Color Theme(""), Marker(0), Marker Theme(""), Continuous Scale(0), Reverse Scale(0), Excluded Rows(0));

        rpt[1][Frame Box(1)] << {Marker Drawing Mode("Outlined")};
		rpt[AxisBox(1)] << Axis Settings({Min(-3), Max(3), Inc(yinc),Minor Ticks(1)});
        rpt[ScaleBox(1)] << {
            Interval("Week"),
            Inc(tinc),
            Minor Ticks(0),
            Label Row({
                Label Orientation("Angled"),
                Show Major Grid(1),
                Show Minor Grid(1)
            })
        };
        If( !Is Missing( time_axis_min ) & !Is Missing( time_axis_max ),
            Try(
                rpt[ScaleBox(1)] << Min( time_axis_min );
                rpt[ScaleBox(1)] << Max( time_axis_max );
            );
        );

        rpt << Set Title( "ALL LAYERS" );	
    ,
        For Each( {rpt}, Treports,
            j=j+1;
            current_by_value = rpt << Get Title;

            rpt[1][Frame Box(1)]  << Row Legend(Column( legendcol1 ),Color( 0 ),Color Theme( "" ),Marker( 0 ),Marker Theme( "" ),Continuous Scale( 0 ),Reverse Scale( 0 ),Excluded Rows( 0 ));
            //rpt[1][Frame Box(1)]  << Row Legend(Column( legendcol2 ),Color( 0 ),Color Theme( "" ),Marker( 0 ),Marker Theme( "" ),Continuous Scale( 0 ),Reverse Scale( 0 ),Excluded Rows( 0 ));

            rpt[1][Frame Box(1)] << {Marker Drawing Mode("Outlined")};
            
            // Find positions of "of " and " By"
            of_pos = Contains(current_by_value, "of ");
            by_pos = Contains(current_by_value, " By ");

            // Extract Y column name between "of " and " By"
            y_col_name = Substr(current_by_value, of_pos + 3, by_pos - of_pos - 3);
            layer_value = Word(-1, current_by_value, "=");
            y_col_display = Substitute(y_col_name, "_", " ");
            
            If(type!="APC",
                trend_stat_suffix = Substitute( Substitute( Substitute( y_col_display, "ALLSTATS ", "" ), "STATISTICS ", "" ), " VALUE", "" );
                _trend_tn = Try( config["layer_to_testname"][Uppercase( layer_value )], "" );
                new_title = Try( config["tech_node_str"], "1278" ) || " " || Try( config["site_str"], "D1V" ) || " FCCD NEST " || layer_value || If( _trend_tn != "", " " || _trend_tn, "" ) || " " || trend_stat_suffix;

                If(type=="MEAN" & no_limits != 1,
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttucl[layer_value], "Solid", UCL_COLOR, ucl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttcl[layer_value], "Solid", CL_COLOR, cl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttlcl[layer_value], "Solid", LCL_COLOR, lcl_label );
                    rpt[AxisBox(1)] << Axis Settings({Min(1.1*recent_limits_mdttlcl[layer_value]), Max(1.1*recent_limits_mdttucl[layer_value]), Inc(yinc),Minor Ticks(1)});
                ); 
                    
                If(type=="SIGMA" & no_limits != 1,
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttucl[layer_value], "Solid", UCL_COLOR, ucl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttcl[layer_value], "Solid", CL_COLOR, cl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttlcl[layer_value], "Solid", LCL_COLOR, lcl_label );
                    rpt[AxisBox(1)] << Axis Settings({Min(1.1*recent_limits_sdttlcl[layer_value]), Max(1.1*recent_limits_sdttucl[layer_value]), Inc(yinc),Minor Ticks(1)});		
                ); 
            ,
                new_title = y_col_display || " " || layer_value;
            );

            rpt[ScaleBox(1)] << {
                Interval("Week"), 
                Inc(tinc),
                Minor Ticks(0),
                Label Row({
                    Label Orientation("Angled"),
                    Show Major Grid(1),
                    Show Minor Grid(1)
                })
            };		
            If( !Is Missing( time_axis_min ) & !Is Missing( time_axis_max ),
                Try(
                    rpt[ScaleBox(1)] << Min( time_axis_min );
                    rpt[ScaleBox(1)] << Max( time_axis_max );
                );
            );

            rpt << Set Title( new_title );	

            If(val_show_splines == 1, rpt[BorderBox(3)] << Visibility("Collapse"));
            rpt[FrameBox(1)]  <<Set Height( rowFBheight ); rpt[FrameBox(1)]  <<Set Width( 500 );

            // Add per-layer copy button for trend charts.
            // Temporarily collapse all ButtonBox controls via Dispatch, copy target, then restore.
            Try(
                copy_target = .;
                copy_target_source = "none";
                Try(
                    Try(
                        copy_target = rpt[OutlineBox(1)];
                        copy_target_source = "OutlineBox(1)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[OutlineBox(2)];
                        copy_target_source = "OutlineBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[ListBox(2)];
                        copy_target_source = "ListBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[FrameBox(1)];
                        copy_target_source = "FrameBox(1)";
                    );
                );
                If( type == "MEAN",
                    button_label = "TrendMEAN";
                    panel_key = "MEAN";
                ,
                    If( type == "SIGMA",
                        button_label = "TrendSIGMA";
                        panel_key = "SIGMA";
                    ,
                        button_label = "TrendAPC";
                        panel_key = "MEAN";
                    );
                );
                Append_Copy_Button( config, layer_value, button_label, trend_chart_object, rpt, "Trend", panel_key );
            );
        );
    );
    
	axisbox = rpt[axis box( 1 )]; axisbox << Show Major Grid( 1 );axisbox << Show Minor Grid( 1 );
    axisbox = rpt[axis box( 2 )]; axisbox << Show Major Grid( 1 );axisbox << Show Minor Grid( 1 );
	
);	

Format_Variability_Charts = Function({var_chart_object, stat, type, xcol, config,vcol, button_label_override},

    // Extract values from config associative array
    recent_limits_mdttucl = config["recent_limits_mdttucl"];
    recent_limits_mdttcl = config["recent_limits_mdttcl"];
    recent_limits_mdttlcl = config["recent_limits_mdttlcl"];
    recent_limits_sdttucl = config["recent_limits_sdttucl"];
    recent_limits_sdttcl = config["recent_limits_sdttcl"];
    recent_limits_sdttlcl = config["recent_limits_sdttlcl"];
    UCL_COLOR = config["UCL_COLOR"];
    CL_COLOR = config["CL_COLOR"];
    LCL_COLOR = config["LCL_COLOR"];
    ucl_label = config["ucl_label"];
    cl_label = config["cl_label"];
    lcl_label = config["lcl_label"];
    ymin = config["ymin"];
    ymax = config["ymax"];
    yinc = config["yinc"];
    varchart_group_width = config["varchart_group_width"];
    tech_str = config["tech_str"];
    no_limits = Try( config["no_limits"], 0 );
    measure_label = Try( config["measure_label"], "DTT" );
    button_label = button_label_override;
    // Unified panel title components
    site_str = Try( config["site_str"], "D1V" );
    tech_node_str = Try( config["tech_node_str"], "1278" );
    ycol_current = If( type == "TARGET",
        If( stat == "MEAN", config["ycol3"], config["ycol4"] ),
        If( stat == "MEAN", config["ycol0"], config["ycol2"] )
    );
    ob3_label = Substitute( Substitute( Substitute( ycol_current, "ALLSTATS_", "" ), "STATISTICS_", "" ), "_VALUE", "" );
    ob3_label = Substitute( ob3_label, "_", " " );
    ob3_label = ob3_label || " BY " || Substitute( vcol, "_", " " );
    // Lazy-build layer → TEST_NAME display map for OB2 (built once per Format_Variability_Charts call)
    If( !Is Associative Array( Try( config["layer_to_testname"], . ) ),
        _lttn = Associative Array();
        _bycol = Try( config["bycol1"], "" );
        _dt_ref = Try( config["dt"], Current Data Table() );
        If( Is Scriptable( _dt_ref ) & _bycol != "",
            Try(
                _lk_col = Column( _dt_ref, _bycol );
                _tn_col = Column( _dt_ref, "TEST_NAME" );
                _nr = N Rows( _dt_ref );
                For( _i = 1, _i <= _nr, _i++,
                    _lk = Uppercase( Trim( Char( _lk_col[_i] ) ) );
                    _tn = Trim( Char( _tn_col[_i] ) );
                    If( _lk != "" & _tn != "",
                        _lttn[_lk] = _tn;
                    );
                );
            );
        );
        config["layer_to_testname"] = _lttn;
    );
            
    Vreports=var_chart_object << Report;
    j=0;
            
    Vreports=var_chart_object << Report;
    j=0;
    For Each( {rpt}, Vreports,
        j=j+1;
        current_by_value = rpt << Get Title;

        rpt[1][Frame Box(1)] << {Marker Drawing Mode("Outlined")};

        // Extract SPC_STATISTIC value (after "SPC_STATISTIC=" at the end)
        wec_layer = Word(-1, current_by_value, "=");
        rpt[1][OutlineBox(2)] << Set Title( ob3_label );

        ob2_display = Try( config["layer_to_testname"][Uppercase( wec_layer )], wec_layer );
        rpt[1][OutlineBox(1)] << Set Title( ob2_display );
        
        axisbox = rpt[1][axis box( 1 )]; axisbox << Show Major Grid( 1 );axisbox << Show Minor Grid( 1 );
        axisbox = rpt[1][axis box( 2 )]; axisbox << Show Major Grid( 1 );axisbox << Show Minor Grid( 1 );
    
        axisbox = rpt[axis box( 1 )]; axisbox << Show Major Grid( 1 ); axisbox << Show Minor Grid( 1 );
        axisbox = rpt[axis box( 2 )]; axisbox << Show Major Grid( 1 ); axisbox << Show Minor Grid( 1 );
    
        mySegs=rpt[FrameBox(1)]<< find segs;
        Filter Each({seg},(mySegs), (seg<< class name)=="BoxPlotSeg") << Set Line Color("Black");
        mySegs=rpt[FrameBox(1)]<< find segs;
        Filter Each({seg},(mySegs), (seg<< class name)=="BoxPlotSeg") << Set Line Color("Black");
        If(type=="DTT",	
            If(stat=="MEAN",				
                rpt << Set Title( tech_node_str || " " || site_str || " FCCD NEST " || wec_layer );
                If( no_limits != 1,
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttucl[wec_layer], "Solid", UCL_COLOR, ucl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttcl[wec_layer], "Solid", CL_COLOR, cl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_mdttlcl[wec_layer], "Solid", LCL_COLOR, lcl_label );
                    rpt[AxisBox(1)] << Axis Settings({Min(1.1*recent_limits_mdttlcl[wec_layer]), Max(1.1*recent_limits_mdttucl[wec_layer]), Inc(yinc),Minor Ticks(0),Label Orientation("Angled")});
                );
            ); 
                
            If(stat=="SIGMA",
                rpt << Set Title( tech_node_str || " " || site_str || " FCCD NEST " || wec_layer );
                If( no_limits != 1,
                    rpt[AxisBox(1)] << Axis Settings({Min(ymin), Max(ymax), Inc(yinc),Minor Ticks(0)});
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttucl[wec_layer], "Solid", UCL_COLOR, ucl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttcl[wec_layer], "Solid", CL_COLOR, cl_label);
                    rpt[AxisBox(1)] << Add Ref Line( recent_limits_sdttlcl[wec_layer], "Solid", LCL_COLOR, lcl_label );
                    rpt[AxisBox(1)] << Axis Settings({Min(1.1*recent_limits_sdttlcl[wec_layer]), Max(1.1*recent_limits_sdttucl[wec_layer]), Inc(yinc),Minor Ticks(0)});			
                );
            ); 
            
            varchart_groups=rpt[AxisBox(2)] << Get Max;
            varchart_width=varchart_groups*varchart_group_width*.6;
            framebox=rpt[FrameBox(1)];
            framebox   <<Set Width( varchart_width );
            framebox << Get Size;
            
            // Determine AxisBox(2) height based on vcol and number of X grouping levels.
            // framebox height = rowFBheight - axisbox2_height keeps total chart height consistent.
            If(vcol == "PROD_MOP_PILOT",
                axisbox2_height = If(xcol == 2, prod_mop_pilot_height + chvfl_height, prod_mop_pilot_height);
                rpt[AxisBox(2)] << Axis Settings({Label Orientation("Angled")});
            ,
                axisbox2_height = If(xcol == 2, chvfl_height * 2, chvfl_height);
            );
            varchart_axisbox = rpt[AxisBox(2)];
            varchart_axisbox << Set Height(axisbox2_height);
            framebox << Set Height(rowFBheight +18- axisbox2_height);

            If(xcol == 2,
                // Single chamber - use XPath with the wec_layer value
                target_textbox = rpt << XPath("(//OutlineBox[text()='ANALYSIS']//OutlineBox[text()='" || wec_layer || "']//TextBox)[2]");
                If(N Items(target_textbox) > 0,
                    target_textbox[1] << Set Text("");
                );
            ,
                // Multiple chambers - check if TextBox(3) exists before accessing
                text_boxes = rpt << XPath("//TextBox");
                If(N Items(text_boxes) >= 3,
                    rpt[TextBox(3)] << Set Text("");
                );
            );
            rpt[TextBox(2)] << Set Text("");

            // Add per-layer copy button for DTT variability charts.
            Try(
                copy_target = .;
                copy_target_source = "none";
                Try(
                    Try(
                        copy_target = rpt[OutlineBox(1)];
                        copy_target_source = "OutlineBox(1)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[OutlineBox(2)];
                        copy_target_source = "OutlineBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[ListBox(2)];
                        copy_target_source = "ListBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[FrameBox(1)];
                        copy_target_source = "FrameBox(1)";
                    );
                );
                panel_key = If( stat == "SIGMA", "SIGMA", "MEAN" );
                Append_Copy_Button( config, wec_layer, button_label, var_chart_object, ., "Var", panel_key );
            );

            
        , //ELSE TYPE == TARGET
            If(stat=="MEAN",
                rpt << Set Title( tech_node_str || " " || site_str || " FCCD NEST " || wec_layer );
            ); 
                
            If(type=="SIGMA",
                rpt << Set Title( tech_node_str || " " || site_str || " FCCD NEST " || wec_layer );
            ); 
            
            varchart_groups=rpt[AxisBox(2)] << Get Max;
            varchart_width=varchart_groups*varchart_group_width*0.6;
            framebox=rpt[FrameBox(1)];
            framebox   <<Set Width( varchart_width );
            
            varchart_axisbox=rpt[AxisBox(2)];			
            varchart_axisbox <<Set Height( prod_mop_pilot_height );
            framebox <<Set Height( 228 );

            // Add per-layer copy button for TARGET variability charts (e.g., MEAN TARGET fifth column).
            Try(
                copy_target = .;
                copy_target_source = "none";
                Try(
                    Try(
                        copy_target = rpt[OutlineBox(1)];
                        copy_target_source = "OutlineBox(1)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[OutlineBox(2)];
                        copy_target_source = "OutlineBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[ListBox(2)];
                        copy_target_source = "ListBox(2)";
                    );
                );
                If( !Is Scriptable( copy_target ),
                    Try(
                        copy_target = rpt[FrameBox(1)];
                        copy_target_source = "FrameBox(1)";
                    );
                );
                button_label = "VarTAR";
                panel_key = If( stat == "SIGMA", "SIGMA", "MEAN" );
                Append_Copy_Button( config, wec_layer, button_label, var_chart_object, ., "Var", panel_key );
            );
        ); 
    );
);

// ============================================================
// MAIN DATA PROCESSING FUNCTION
// ============================================================
ProcessSDTTData = Function({val_cb_close_reports_and_windows, val_data_type, chamber_list, selected_member, val_include_sigma, val_no_splines, val_dataset, val_site, val_apc_suc_only, val_include_full_history, val_apc_model, dlg_win, val_current_target_only = 0, val_measure = 1},
    
    // Derive dataset label for use in titles
    tech_str = If(val_dataset == 1, "1278", "1280");
    dataset_title_str = If(
        val_dataset == 1,
        If( val_site == 1, "1278 D1V", "1278 F32" ),
        "1280 D1V"
    );

    // Configuration object
    config = Associative Array();
    config["window_title"] = dataset_title_str || " FCCD SDTT Report";
    config["site_str"] = If( val_dataset == 1, If( val_site == 1, "D1V", "F32" ), "D1V" );
    config["tech_node_str"] = If( val_dataset == 1, "1278", "1280" );
    config["varchart_group_width"] = 40;
    config["LIMIT_COLOR"] = "Black";
    config["vcol1"] = "CHAMBER";	
    config["vcol2"] = "PROD_MOP_PILOT";
    config["vcol3"] = "PROD_MOP_PILOT";
    config["bycol1"] = "WEC_LAYER";		
    config["xcol"] = "DATA_COLLECTION_TIME";		
    config["legendcol1"] = "CHAMBER";		
    //config["legendcol2"] = "PRODUCT_GROUP";
    config["title"] = "SDTT";	
    config["ycol0"] = "ALLSTATS_MEAN_DTT_VALUE";	
    config["ycol1"] = "APC_B_TOOL";	
    config["ycol2"] = "ALLSTATS_SIGMA_DTT_VALUE";
    config["ycol3"] = "ALLSTATS_MEAN_TARGET_VALUE";
    config["ycol4"] = "ALLSTATS_SIGMA_TARGET_VALUE";
    config["filter_str"] = "SMP SDTT";
    config["UZ1_COLOR"] = "Blue";
    config["uz1_label"] = "UZ1";
    config["UCL_COLOR"] = "Red";
    config["ucl_label"] = "UCL";
    config["CL_COLOR"] = "Black";
    config["cl_label"] = "";
    config["LCL_COLOR"] = "Red";
    config["lcl_label"] = "LCL";
    config["LZ1_COLOR"] = "Blue";
    config["lz1_label"] = "LZ1";
    config["ymin"] = -1.5;
    config["ymax"] = 1.5;
    config["tinc"] = If( val_include_full_history == 1, 2, 1 );
    config["yinc"] = 0.2;
    config["jittered"] = 0;
    config["show_splines"] = 1 - val_no_splines;
    config["tech_str"] = tech_str;
    config["dataset_title_str"] = dataset_title_str;

    // Select source path.
    // FCCD has a single file per site — no APC or 60-day variants.
    If( val_dataset == 1,
        path = If( val_site == 1, path_1278_d1v, path_1278_f32 );
    ,
        path = path_1280;
    );
    Debug_Trace( "Resolved source path: " || Char( path ) );
    If( !File Exists( path ),
        Debug_Trace( "Source path missing/unreadable: " || Char( path ) );
        Throw( "Missing source CSV: " || Char( path ) );
    );

    // Apply close reports/windows BEFORE opening new data.
    // Use a manual loop instead of Close All("Reports") so the input dialog survives.
    If(val_cb_close_reports_and_windows == 1,
        For Each({win_obj}, Get Window List(),
            If(win_obj != dlg_win,
                Try(win_obj << Close Window("NoSave"));
            );
        );
        Close All("Data Tables", "NoSave");
    );

    dt = Open(path); 
    dt = Current Data Table();
    config["dt"] = dt;

    // DATA TYPE PROCESSING
    If(val_data_type != 1,
        // ALLSTATS selected - use ALLSTATS columns
        config["ycol0"] = "ALLSTATS_MEAN_DTT_VALUE";
        config["ycol2"] = "ALLSTATS_SIGMA_DTT_VALUE";
        data_type_str = "ALLSTATS";
    ,
        // SPC selected - use STATISTICS columns and filter data
        config["ycol0"] = "STATISTICS_MEAN_DTT_VALUE";
        config["ycol2"] = "STATISTICS_SIGMA_DTT_VALUE";
        data_type_str = "SPC";
        
        // Delete rows where ALLSTATS_DYNWAFER != "DYNWAFER_001"
        dt << Select Where(:ALLSTATS_DYNWAFER != "DYNWAFER_001");
        dt << Delete Rows;
        dt << Clear Select;
    );

    // ---- MEASURE override: WAFER mode replaces DTT Y columns and disables limit lines ----
    If( val_measure == 2,
        config["ycol0"] = "ALLSTATS_WAFER_MEAN_VALUE";
        config["ycol2"] = "ALLSTATS_WAFER_SIGMA_VALUE";
        config["no_limits"] = 1;
        config["measure_label"] = "WAFER";
    ,
        config["no_limits"] = 0;
        config["measure_label"] = "DTT";
    );

    // ---- Target regime filter (current target only) ----
    If( val_current_target_only == 1,
        Apply_Target_Regime_Filter( dt );
    );

    // Filter to APC feedback success rows only (APC_FB_SUC == 1) — guarded for FCCD
    If(val_apc_suc_only == 1,
        Try(
            dt << Select Where(:APC_FB_SUC != 1);
            dt << Delete Rows;
            dt << Clear Select;
        );
    );

    // Filter by APC MODEL selection — guarded for FCCD
    If( val_apc_model == 2,
        Try(
            dt << Select Where( :APC_AREA != "AMECT_ICCR2" );
            dt << Delete Rows;
            dt << Clear Select;
        );
    ,
        If( val_apc_model == 3,
            Try(
                dt << Select Where( :APC_AREA != "MFGAMECT_FLOW_TEMP" );
                dt << Delete Rows;
                dt << Clear Select;
            );
        );
    );

    // Shared x-axis window for all time-trend charts (MEAN/APC/SIGMA).
    time_axis_min = Col Min( :DATA_COLLECTION_TIME );
    time_axis_max = Col Max( :DATA_COLLECTION_TIME );
    If( !Is Missing( time_axis_min ) & !Is Missing( time_axis_max ),
        time_axis_min = time_axis_min - In Days( 1 );
        time_axis_max = time_axis_max + In Days( 1 );
    );
    config["time_axis_min"] = time_axis_min;
    config["time_axis_max"] = time_axis_max;
    Debug_Trace( "Shared time axis min=" || Char( time_axis_min ) || " max=" || Char( time_axis_max ) );

    // chamber_list is already set from dialog selection above
    // FCCD uses AME_ETCH column instead of SUBENTITY to identify the etch chamber
    dt << New Column( "CHAMBER",Character,Set Each Value(If(Contains( chamber_list, :AME_ETCH ),:AME_ETCH,"FLEET")));

    // Color or mark by column
    dt << Color or Mark by Column(:CHAMBER,Color Theme( "JMP Vibrant"(1) ),Marker Theme( "Solid" ),Continuous Scale( 0 ));

    // Then override FLEET rows to black
    dt << Select Where(:CHAMBER == "FLEET");
    dt << Colors(Black);
    dt << Markers(Dot);
    dt << Select Where(:CHAMBER != "FLEET");

    // Update window title to replace "Report" with data type
    updated_window_title = Substitute(config["window_title"], "Report", data_type_str);
    If( val_measure == 2,
        updated_window_title = updated_window_title || " WAFER";
    );
    dt << Set Name(selected_member || " - " || updated_window_title || " Data"); 
    dt << Set Label Columns( :SPC_LOT );

    // Get the list of unique values from the :WEC_LAYER column to use as keys for initialized Associative Arrays
    unique_layers = Associative Array( dt:WEC_LAYER ) << Get Keys;	
    recent_limits_mdttucl= Associative Array();
    recent_limits_mdttcl= Associative Array();
    recent_limits_mdttlcl= Associative Array();
    recent_limits_sdttucl= Associative Array();
    recent_limits_sdttcl= Associative Array();
    recent_limits_sdttlcl= Associative Array();
    
    For( i = 1, i <= N Items( unique_layers ), i++,
        current_layer = unique_layers[i];
        first_row_for_layer = dt << Get Rows Where( :WEC_LAYER == current_layer  & :IS_POR == "True")[1];
        rows= dt << Get Rows Where( :WEC_LAYER == current_layer & :IS_POR == "True"); 
        first_row_for_layer=rows[1];
        recent_limits_mdttucl[current_layer]=dt:STATISTICS_MEAN_DTT_UCL[first_row_for_layer];	
        recent_limits_mdttcl[current_layer]=dt:STATISTICS_MEAN_DTT_CENTERLINE[first_row_for_layer];	
        recent_limits_mdttlcl[current_layer]=dt:STATISTICS_MEAN_DTT_LCL[first_row_for_layer];	
        recent_limits_sdttucl[current_layer]=dt:STATISTICS_SIGMA_DTT_UCL[first_row_for_layer];	
        recent_limits_sdttcl[current_layer]=dt:STATISTICS_SIGMA_DTT_CENTERLINE[first_row_for_layer];	
        recent_limits_sdttlcl[current_layer]=dt:STATISTICS_SIGMA_DTT_LCL[first_row_for_layer];	
    );

    // Add limits to config for functions
    config["recent_limits_mdttucl"] = recent_limits_mdttucl;
    config["recent_limits_mdttcl"] = recent_limits_mdttcl;
    config["recent_limits_mdttlcl"] = recent_limits_mdttlcl;
    config["recent_limits_sdttucl"] = recent_limits_sdttucl;
    config["recent_limits_sdttcl"] = recent_limits_sdttcl;
    config["recent_limits_sdttlcl"] = recent_limits_sdttlcl;

    // Extract frequently used config values
    ycol0 = config["ycol0"];
    ycol1 = config["ycol1"];
    ycol2 = config["ycol2"];
    ycol3 = config["ycol3"];
    ycol4 = config["ycol4"];
    vcol1 = config["vcol1"];
    vcol2 = config["vcol2"];
    vcol3 = config["vcol3"];
    bycol1 = config["bycol1"];
    xcol = config["xcol"];
    legendcol1 = config["legendcol1"];
    //legendcol2 = config["legendcol2"];
    filter_str = config["filter_str"];

    copy_button_list_mean = V List Box();
    copy_button_panel_mean = Outline Box( "COPY MEAN", copy_button_list_mean );
    copy_button_list_sigma = V List Box();
    copy_button_panel_sigma = Outline Box( "COPY SIGMA", copy_button_list_sigma );

    config["copy_button_list_mean"] = copy_button_list_mean;
    config["copy_button_list_sigma"] = copy_button_list_sigma;

    copy_button_list_mean_runtime = copy_button_list_mean;
    copy_layer_boxes_mean_runtime = Associative Array();
    copy_layer_label_boxes_mean_runtime = Associative Array();
    copy_button_list_sigma_runtime = copy_button_list_sigma;
    copy_layer_boxes_sigma_runtime = Associative Array();
    copy_layer_label_boxes_sigma_runtime = Associative Array();

    // Create the main window
    SDTT_win=New Window(selected_member || " - " || updated_window_title,
        lb = V List Box(
            myTitle = "ALL PRODUCTS "||filter_str;

            V List Box(		
                ///////////////////////////////////////////////////////////////////////////////
                //INFO BOX ////////////////////////////////////////////////////////////////////
                ///////////////////////////////////////////////////////////////////////////////	
                dt << FitGroup(
                    dt << Distribution(Stack( 1 ),Arrange in Rows( 7 ),
                        Nominal Distribution(Column( :TEST_NAME ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :LOT_TYPE ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :PRODUCT_GROUP ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :PRODUCT ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :ROUTE_TYPE ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :IS_POR ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Title("LOTS"),SendToReport(Dispatch({},"LOTS",OutlineBox,{Close( 1 )})),
                    ),
                            
                    dt << Distribution(Stack( 1 ),Arrange in Rows( 6 ),
                        Nominal Distribution(Column( :WEC_LAYER ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :WEC_ALIAS ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :WEC_OPERATION ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :WEC_ENTITY ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :SUBENTITY ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :WEC_RECIPE ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Title("WEC"),SendToReport(Dispatch({},"WEC",OutlineBox,{Close( 1 )})), 
                    ),
                
                    dt << Distribution(Stack( 1 ),Arrange in Rows( 6 ),		
                        Nominal Distribution(Column( :SPC_ALIAS ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :SPC_OPERATION ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :PRIMARY_ENTITY ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :ANALYTICAL_ENTITY ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :SPC_RECIPE ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),
                        Nominal Distribution(Column( :ALLSTATS_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_MEAN_DTT_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_PERCENT_MEASURED_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_SIGMA_DTT_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_WAFER_MEAN_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_WAFER_PERCENT_OOS_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Nominal Distribution(Column( :STATISTICS_WAFER_SIGMA_STANDARD_FLAG ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 1 )),			
                        Title("SPC"), ,SendToReport(Dispatch({},"SPC",OutlineBox,{Close( 1 )})), 
                    ),
                    SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( "DISTRIBUTIONS" ), Close ( 0 ) })), <<{Arrange in Rows( 3 )}
                );,

                ///////////////////////////////////////////////////////////////////////////////
                //SUM TREND AND VAR CHART FIT GROUPS///////////////////////////////////////////
                ///////////////////////////////////////////////////////////////////////////////
				H List Box(
					all="ALL";	mean="MEAN";sigma="SIGMA";apc="APC";target="TARGET";dtt="DTT";
					fg_trend_dtt_mean_all= dt << FitGroup(
						trend_dtt_mean_all=Bivariate(Y( Column( ycol0)),X( Column ( xcol ) )),
						SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" DTT"), Close ( 0 ) })),
					);
					Format_Trend_Charts(trend_dtt_mean_all,all,config);, 
					
					// Add Data Filter
					dt << Data Filter(	Location( {0, 0} ),	Width( 800 ), Add Filter(	columns( :DATA_COLLECTION_TIME, :CHAMBER )));

				), //H List Box end


                H List Box(
                    copy_button_panel_mean,
                    fg_trend_dtt_mean= dt << FitGroup(
                        trend_dtt_mean=Bivariate(Y( Column( ycol0)),X( Column ( xcol ) ),By( Column ( bycol1 )),
                            GroupBy( Column( legendcol1) ),
                        ),
                        SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" DTT BY "||bycol1 ), Close ( 0 ) })),
                    );
                    If(val_show_splines == 1, trend_dtt_mean << Fit Spline(0.1, Standardized, {Report( 0 ), Line Width( 0.1)}));
                    Format_Trend_Charts(trend_dtt_mean,mean,config);, 

                    fg_var_dtt_mean= dt << FitGroup(
                        var_dtt_mean = dt << Variability Chart(
                            Y( Column( ycol0) ),X( Column ( vcol1 )),
                            By ( Column( bycol1)) , Connect Cell Means(1), Show Cell Means(1), Show Box Plots(1)
                        ),
                        SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                    );
                    Format_Variability_Charts(var_dtt_mean,mean,dtt,1,config,vcol1,"VarCHAM");,
                    
                    If(N Items(chamber_list) == 1,
                        // Single chamber - use two X columns
                        fg_var_dtt_mean_prod = dt << FitGroup(
                            var_dtt_mean_prod = dt << Variability Chart(
                                Y( Column( ycol0) ),
                                X( Column( vcol2 ), Column( vcol1 )),
                                By ( Column( bycol1)) , 
                                Connect Cell Means(1), 
                                Show Cell Means(1), 
                                Show Box Plots(1)
                            ),
                            SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                        );
                        Format_Variability_Charts(var_dtt_mean_prod,mean,dtt,2,config,vcol2,"VarPROD");
                    ,
                        // Multiple chambers - use single X column (current implementation)
                        fg_var_dtt_mean_prod = dt << FitGroup(
                            var_dtt_mean_prod = dt << Variability Chart(
                                Y( Column( ycol0) ),
                                X( Column ( vcol2 )),
                                By ( Column( bycol1)) , 
                                Connect Cell Means(1), 
                                Show Cell Means(1), 
                                Show Box Plots(1)
                            ),
                            SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                        );
                        Format_Variability_Charts(var_dtt_mean_prod,mean,dtt,1,config,vcol2,"VarPROD");
                    );
                    
                    fg_var_dtt_mean_tar= dt << FitGroup(
                        var_dtt_mean_tar = dt << Variability Chart(
                            Y( Column( ycol3) ),X( Column ( vcol3 )),
                            By ( Column( bycol1)) , Connect Cell Means(1), Show Cell Means(1), Show Box Plots(1)
                        ),
                        SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( mean||" TARGET BY "||bycol1 ), Close ( 0 ) })), 
                    );
                    Format_Variability_Charts(var_dtt_mean_tar,mean,target,1,config,vcol3,"VarTAR");,

                    If(val_include_sigma == 1,
                        copy_button_panel_sigma
                    );,

                    If(val_include_sigma == 1,
                            fg_trend_dtt_sigma= dt << FitGroup(
                            trend_dtt_sigma=Bivariate(Y( Column( ycol2)),X( Column ( xcol ) ),By( Column ( bycol1 )),
                                GroupBy( Column( legendcol1) ),
                            ),
                            SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( sigma||" DTT BY "||bycol1 ), Close ( 0 ) })),
                        );
                        If(val_show_splines == 1, trend_dtt_sigma << Fit Spline(0.1, Standardized, {Report( 0 ), Line Width( 0.1)}));
                        Format_Trend_Charts(trend_dtt_sigma,sigma,config)
                    );, 

                    If(val_include_sigma == 1,
                        fg_var_dtt_sigma= dt << FitGroup(
                            var_dtt_sigma = dt << Variability Chart(
                                Y( Column( ycol2) ),X( Column ( vcol1 )),
                                By ( Column( bycol1)) , Connect Cell Means(1), Show Cell Means(1), Show Box Plots(1)
                            ),
                            SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( sigma||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                        );
                        Format_Variability_Charts(var_dtt_sigma,sigma,dtt,1,config,vcol1,"VarCHAM")
                    );,
                    
                    If(val_include_sigma == 1,
                        If(N Items(chamber_list) == 1,
                            // Single chamber - use two X columns
                            fg_var_dtt_sigma_prod = dt << FitGroup(
                                var_dtt_sigma_prod = dt << Variability Chart(
                                    Y( Column( ycol2) ),
                                    X( Column( vcol2 ), Column( vcol1 )),
                                    By ( Column( bycol1)) , 
                                    Connect Cell Means(1), 
                                    Show Cell Means(1), 
                                    Show Box Plots(1)
                                ),
                                SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( sigma||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                            );
                            Format_Variability_Charts(var_dtt_sigma_prod,sigma,dtt,2,config,vcol2,"VarPROD");
                        ,
                            // Multiple chambers - use single X column (current implementation)
                            fg_var_dtt_sigma_prod = dt << FitGroup(
                                var_dtt_sigma_prod = dt << Variability Chart(
                                    Y( Column( ycol2) ),
                                    X( Column ( vcol2 )),
                                    By ( Column( bycol1)) , 
                                    Connect Cell Means(1), 
                                    Show Cell Means(1), 
                                    Show Box Plots(1)
                                ),
                                SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( sigma||" DTT BY "||bycol1 ), Close ( 0 ) })), 
                            );
                            Format_Variability_Charts(var_dtt_sigma_prod,sigma,dtt,1,config,vcol2,"VarPROD");
                        );
                        
                        fg_var_dtt_sigma_tar= dt << FitGroup(
                            var_dtt_sigma_tar = dt << Variability Chart(
                                Y( Column( ycol4) ),X( Column ( vcol3 )),
                                By ( Column( bycol1)) , Connect Cell Means(1), Show Cell Means(1), Show Box Plots(1)
                            ),
                            SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( sigma||" TARGET BY "||bycol1 ), Close ( 0 ) })), 
                        );
                        Format_Variability_Charts(var_dtt_sigma_tar,sigma,target,1,config,vcol3,"VarTAR")
                    );,
                )
            ), 
        )		 
    ); 

    // Then override FLEET rows to black
    dt << Select Where(:CHAMBER == "FLEET");
    dt << Colors(Gray);
    dt << Select Where(:CHAMBER != "FLEET");

    // Maximize the window after creation
    SDTT_win << Maximize Window;

    Show("Data processing completed for: ", selected_member);
);

// ============================================================
// PERSISTENT USER INPUT DIALOG
// ============================================================
Run_Generate_Report = Function( {},
    Debug_Trace( "Run_Generate_Report click start" );

    // Get current values from dialog
    val_cb_close_reports_and_windows = cb_close_reports_and_windows << Get;
    val_include_full_history = cb_include_full_history << Get;
    val_include_sigma = cb_include_sigma << Get;
    val_no_splines = cb_no_splines << Get;
    val_apc_suc_only = cb_apc_suc_only << Get;
    val_current_target_only = cb_current_target_only << Get;
    val_apc_model = rbApcModel << Get;
    val_measure = rbMeasure << Get;
    val_dataset_choice = rbDataset << Get;
    If( val_dataset_choice == 1,
        val_dataset = 1;
        val_site = 1;
    ,
        If( val_dataset_choice == 2,
            val_dataset = 1;
            val_site = 2;
        ,
            val_dataset = 2;
            val_site = 1;
        );
    );
    val_data_type = rbDataType << Get;
    val_chamber_index = rbChamber << Get;
    Debug_Trace(
        "Inputs dataset_choice=" || Char( val_dataset_choice ) ||
        " include_full_history=" || Char( val_include_full_history ) ||
        " apc_suc_only=" || Char( val_apc_suc_only ) ||
        " data_type=" || Char( val_data_type )
    );

    // Resolve chamber override
    picker_raw_d1v = subentity_picker_lb_d1v << Get Selected;
    picker_selection_d1v = Normalize_Subentity_Selection( picker_raw_d1v, subentity_picker_visible_d1v );
    picker_raw_f32 = subentity_picker_lb_f32 << Get Selected;
    picker_selection_f32 = Normalize_Subentity_Selection( picker_raw_f32, subentity_picker_visible_f32 );

    picker_selection = picker_selection_d1v;
    For( i = 1, i <= N Items( picker_selection_f32 ), i++,
        Insert Into( picker_selection, picker_selection_f32[i] );
    );
    If( N Items( picker_selection ) > 0,
        picker_selection = Associative Array( picker_selection ) << Get Keys;
        Sort List( picker_selection );
    );
    Debug_Trace( "Picker selection count=" || Char( N Items( picker_selection ) ) );

    If( N Items( picker_selection ) > 0,
        subentity_picker_selected = picker_selection;
        chamber_list = subentity_picker_selected;
        selected_member = "CUSTOM PICKER: " || Char( N Items( chamber_list ) ) || " SUBENTITY";
    ,
        SUBENTITY_STR = Trim(SUBENTITY_TB << Get Text());
        If(SUBENTITY_STR != "",
            chamber_list = Words(SUBENTITY_STR, ",");
            For(i = 1, i <= N Items(chamber_list), i++,
                chamber_list[i] = Trim(chamber_list[i]);
            );
            selected_member = "CUSTOM: " || SUBENTITY_STR;
        ,
            ENTITY_STR = Trim(ENTITY_TB << Get Text());
            PM_STR = Trim(PM_TB << Get Text());
            If(ENTITY_STR != "" & PM_STR != "",
                CHAMBER_STR = "AME4" || ENTITY_STR || "_PM" || PM_STR;
                chamber_list = {};
                Insert Into(chamber_list, CHAMBER_STR);
                selected_member = "CUSTOM: " || CHAMBER_STR;
            ,
                chamber_list = chamber_data[val_chamber_index][2];
                selected_member = chamber_data[val_chamber_index][1];
            );
        );
    );
    Debug_Trace( "Resolved chamber_list count=" || Char( N Items( chamber_list ) ) || " selected_member=" || selected_member );

    // Call the data processing function
    Try(
        ProcessSDTTData(val_cb_close_reports_and_windows, val_data_type, chamber_list, selected_member, val_include_sigma, val_no_splines, val_dataset, val_site, val_apc_suc_only, val_include_full_history, val_apc_model, dialog_window, val_current_target_only, val_measure);
        Debug_Trace( "Run_Generate_Report click success" );
    ,
        Debug_Trace( "Run_Generate_Report click failure" );
        Show( "CHAMBER_DISPO_ERROR", "Generate Report failed", "dataset_choice", val_dataset_choice, "val_dataset", val_dataset, "val_site", val_site, "selected_member", selected_member );
        Throw();
    );
);

dialog_window = New Window( "FCCD SDTT Report Options", 
    V List Box(
        H List Box(
            V List Box(
                Panel Box("Tool Owner",
                    rbChamber = Radio Box( {"Trey", "Kayden", "Chang", "Adi", "Travis", "Tyler", "Mathius", "Sashank", "William", "Minog"} ),
                ),
                Panel Box("DATASET",
                    rbDataset = Radio Box( {"1278 D1V", "1278 F32", "1280 D1V"} ),
                )
            ),
            V List Box(
                Panel Box("SINGLE SUBENTITY & LIST OVERRIDE",
                    Lineup Box(N Col(7),
                        Text Box( "AME4" ), ENTITY_TB = Text Edit Box( "", <<Set Width( 25 ) ),
                        Text Box( "_PM" ), PM_TB = Text Edit Box( "", <<Set Width( 12 ) ),
                        Spacer Box(Size(10, 10)),
                        Text Box( "  — or full SUBENTITY:" ), SUBENTITY_TB = Text Edit Box( "", <<Set Width( 100 ) ),
                    ),
                ),
                H List Box(
                    Panel Box("SUBENTITY FORM OVERRIDE",
                        V List Box(
                            subentity_tab_box = Tab Box(
                                "D1V",
                                V List Box(
                                    H List Box(
                                        SUBENTITY_FILTER_TB_D1V = Text Edit Box( "", <<Set Width( 90 ) ),
                                        Button Box( "Search",
                                            filter_text = SUBENTITY_FILTER_TB_D1V << Get Text;
                                            subentity_picker_visible_d1v = Filter_Subentity_Fleet_List( subentity_fleet_d1v, filter_text );
                                            subentity_picker_lb_d1v << Set Items( subentity_picker_visible_d1v );
                                        )
                                    ),
                                    subentity_picker_lb_d1v = List Box( subentity_picker_visible_d1v, Max Selected( 200 ) ),
                                    subentity_picker_lb_d1v << Set N Lines( 8 ),
                                    subentity_picker_lb_d1v << Set Width( 125 ),
                                    subentity_picker_lb_d1v << Set Height( 160 )
                                ),
                                "F32",
                                V List Box(
                                    H List Box(
                                        SUBENTITY_FILTER_TB_F32 = Text Edit Box( "", <<Set Width( 90 ) ),
                                        Button Box( "Search",
                                            filter_text = SUBENTITY_FILTER_TB_F32 << Get Text;
                                            subentity_picker_visible_f32 = Filter_Subentity_Fleet_List( subentity_fleet_f32, filter_text );
                                            subentity_picker_lb_f32 << Set Items( subentity_picker_visible_f32 );
                                        )
                                    ),
                                    subentity_picker_lb_f32 = List Box( subentity_picker_visible_f32, Max Selected( 200 ) ),
                                    subentity_picker_lb_f32 << Set N Lines( 8 ),
                                    subentity_picker_lb_f32 << Set Width( 125 ),
                                    subentity_picker_lb_f32 << Set Height( 160 )
                                )
                            ),
                            H List Box(
                                Button Box( "Clear Selected",
                                    subentity_picker_selected = {};
                                    subentity_picker_lb_d1v << Set Items( subentity_picker_visible_d1v );
                                    subentity_picker_lb_f32 << Set Items( subentity_picker_visible_f32 );
                                )
                            )
                        )
                    ),
                    V List Box(
                        Panel Box("OPTIONS",
                            V List Box(
							cb_close_reports_and_windows = Check Box( "Close Reports & Windows" ),
                                cb_include_full_history = Check Box( "Include Full History" ),
                                cb_include_sigma = Check Box( "Include Sigma Charts" ),
                                cb_no_splines = Check Box( "No Splines" ),
                                cb_apc_suc_only = Check Box( "APC_FB_SUC=1" ),
                                cb_current_target_only = Check Box( "Current Target Only" ),
                            ),
                        ),
                        Panel Box("APC MODEL",
                            rbApcModel = Radio Box(
                                {"All Models", "AMECT_ICCR2", "MFGAMECT_FLOW_TEMP"}
                            ),
                        ),
                        Panel Box("MEASURE",
                            rbMeasure = Radio Box( {"DTT", "WAFER"} ),
                        ),
                        Panel Box("DATA TYPE",
                            rbDataType = Radio Box(
                                {"SPC (chart points only)","ALLSTATS (all measured wafers)"}
                            ),
                        ),
                        H List Box(
                            Button Box( "Generate Report",
                                Run_Generate_Report();
                            ),
                            Button Box( "Close Dialog",
                                dialog_window << Close Window;
                            )
                        )
                    )
                )
            ) // H List Box (buttons)
        ), // V List Box (right column)
    ), // H List Box (top-level left/right split)
);


// Usage tracking - final version
log_path = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\backups\sDTT_Chamber_Dispo_log.txt";
usage_tracking_enabled = 0;

track_usage = Function({},
    If( usage_tracking_enabled != 1,
        Return();
    );

    Try(
        timestamp = Char(Today());
        log_entry = timestamp || " - Script usage" || "\n";
        
        // Check if file exists to append or create
        If(File Exists(log_path),
            current_content = Load Text File(log_path);
            new_content = current_content || log_entry;
            Save Text File(log_path, new_content);
        ,
            Save Text File(log_path, log_entry);
        );
    ,
        // Silent fail if there are any issues
    );
);

// Call this at the beginning of your main script
track_usage();
