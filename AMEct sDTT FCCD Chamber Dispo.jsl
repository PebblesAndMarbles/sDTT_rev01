Build_Subentity_Fleet_List = Function( {},
    raw_list = {};
    For( owner_i = 1, owner_i <= N Items( chamber_data ), owner_i++,
        owner_chambers = chamber_data[owner_i][2];
        For( chamber_i = 1, chamber_i <= N Items( owner_chambers ), chamber_i++,
            Insert Into( raw_list, Char( owner_chambers[chamber_i] ) );
        );
    );
    out_list = Associative Array( raw_list ) << Get Keys;
    Sort List( out_list );
);

Filter_Subentity_Fleet_List = Function( {fleet_list, raw_filter},
    needle = Uppercase( Trim( Char( raw_filter ) ) );
    If( needle == "",
        Return( fleet_list );
    );

    filtered = {};
    For( i = 1, i <= N Items( fleet_list ), i++,
        item = Char( fleet_list[i] );
        If( Contains( Uppercase( item ), needle ),
            Insert Into( filtered, item );
        );
    );
    filtered;
);

Normalize_Subentity_Selection = Function( {raw_selection, visible_items},
    out = {};

    If( Is List( raw_selection ),
        For( i = 1, i <= N Items( raw_selection ), i++,
            item = Char( raw_selection[i] );
            If( Contains( visible_items, item ),
                Insert Into( out, item );
            );
        );
    ,
        If( Type( raw_selection ) == "Matrix",
            n_sel = N Row( raw_selection );
            For( i = 1, i <= n_sel, i++,
                idx = Num( raw_selection[i] );
                If( 1 <= idx <= N Items( visible_items ),
                    Insert Into( out, Char( visible_items[idx] ) );
                );
            );
        ,
            If( Type( raw_selection ) == "String" & raw_selection != "",
                Insert Into( out, raw_selection );
            );
        );
    );

    If( N Items( out ) > 0,
        out = Associative Array( out ) << Get Keys;
        Sort List( out );
    );
    out;
);

