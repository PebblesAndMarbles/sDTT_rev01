path_1280_karc_d1v = karc_integrated_output_dir || "1280sDTT_KARC_FCCD_D1V_Ed.csv";
karc_prod_targeting_output_dir = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\sDTT\sDTT_rev01\adaptations\1280KARC\prod_targeting\";
report_output_dir = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\sDTT\sDTT_rev01\prod_targeting\";

debug_log_path = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\sDTT\sDTT_rev01\prod_targeting\sDTT_Prod_Targeting_Report_TEST_debug.txt";
debug_log = "";
last_combined_window_title = "";
dt_main_review = .;
current_metric_cfg = .;
current_tech_str = "";
report_product_family = "FCCD";
report_layer_title_value = "MT1";

by_col        = "WEC_LAYER";
time_col      = "DATA_COLLECTION_TIME";
pilot_col     = "PROD_MOP_PILOT";
site_col      = "SPC_SITE";
site_pilot_col = "SITE_PROD_MOP_PILOT";
allowed_structures = {"NESTVIA_PR", "NESTVIA_HM", "TRENCH", "ETE"};

total_panel_height    = 420;
trend_frame_width     = 400;
var_frame_height      = 300;
varchart_group_width  = 40;
var_chart_width_scale = 1.10;
use_uniform_var_width = 0;
