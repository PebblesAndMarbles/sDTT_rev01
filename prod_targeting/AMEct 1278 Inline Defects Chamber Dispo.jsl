	_max_yymm = Get_Max_YYMM_From_Table(dt);
	_max_period_index = YYMM_To_Period_Index(_max_yymm);
	If(!Is Missing(_max_period_index),
		_cutoff_period_index = _max_period_index - (val_yymm_lookback_periods - 1);
		yymm_cutoff_value = Period_Index_To_YYMM(_cutoff_period_index);
		_removed_dt_rows = Apply_YYMM_Lookback_Filter(dt, _cutoff_period_index);
		_removed_coord_rows = Apply_YYMM_Lookback_Filter(dt_coords, _cutoff_period_index);
		Print(
			"YYMM lookback filter applied - periods=" || Char(val_yymm_lookback_periods) ||
			" max_yymm=" || Char(_max_yymm) ||
			" cutoff_yymm=" || Char(yymm_cutoff_value) ||
			" removed_rows(metrics,coords)=(" || Char(_removed_dt_rows) || "," || Char(_removed_coord_rows) || ")"
		);
		selected_source_name = selected_source_name || " cutoff>= " || Char(yymm_cutoff_value);
	,
		Print("YYMM lookback requested but no valid YYMM values were found; leaving tables unfiltered.");
	);
);

// Build ORIGINAL_ROW_NUMBER in dt_coords: maps each coord row to the
// corresponding row index in dt (joined on WAFER_ID + LAYER).
// Used by MakeRowStateHandler for O(1) row propagation without key strings.
_key_map = Associative Array();
For(_r = 1, _r <= N Rows(dt), _r++,
    _key_map[Column(dt,"WAFER_ID")[_r] || "|" || Column(dt,"LAYER")[_r]] = _r;
);
dt_coords << New Column("ORIGINAL_ROW_NUMBER", Numeric, Continuous);
For(_r = 1, _r <= N Rows(dt_coords), _r++,
    _k = Column(dt_coords,"WAFER_ID")[_r] || "|" || Column(dt_coords,"LAYER")[_r];
	_v = .;
	Try(
		_v = _key_map[_k];
	,
		_v = .;
	);
    If(!Is Missing(_v),
        Column(dt_coords,"ORIGINAL_ROW_NUMBER")[_r] = _v;
    );
);
Print("ORIGINAL_ROW_NUMBER built for " || Char(N Rows(dt_coords)) || " coord rows");

// chamber_list is already set from dialog selection above
dt << New Column( "CHAMBER",Character,Set Each Value(If(Contains( chamber_list, :SUBENTITY ),:SUBENTITY,"FLEET")));

// Color or mark by column
dt << Color or Mark by Column(:CHAMBER,Color Theme( "JMP Vibrant"(1) ),Marker Theme( "Solid" ),Continuous Scale( 0 ));

// Then override FLEET rows to black
dt << Select Where(:CHAMBER == "FLEET");
dt << Colors(Gray);
dt << Markers(Dot);

// Propagate CHAMBER column + identical color/marker scheme to dt_coords
// so wafermaps inherit chamber colors without needing a Row Legend call.
dt_coords << New Column("CHAMBER", Character,
    Set Each Value(
        _orn = Column(dt_coords,"ORIGINAL_ROW_NUMBER")[Row()];
        If(!Is Missing(_orn), Column(dt,"CHAMBER")[_orn], "FLEET")
    )
);
dt_coords << Color or Mark by Column(:CHAMBER, Color Theme("JMP Vibrant"(1)), Marker Theme("Solid"), Continuous Scale(0));
dt_coords << Select Where(:CHAMBER == "FLEET");
dt_coords << Colors(Gray);
dt_coords << Markers(Dot);
dt_coords << Clear Select;

// Hide/exclude FLEET coordinate rows when "Show FLEET Coordinates" is unchecked (default)
If(val_show_fleet == 0,
    dt_coords << Select Where(:CHAMBER == "FLEET");
    dt_coords << Hide and Exclude;
    dt_coords << Clear Select;
);

dt << Set Name(selected_member || " - " || window_title || " Data"); dt << Set Label Columns( :LOT );

// ============================================================
// HIGHFLIER / BASELINE FILTER
// 1 = Hide Highfliers NOT in chamber_list  (default)
// 2 = Hide ALL Highfliers
// 3 = Hide BASELINE rows
// 4 = Hide / Exclude nothing (show all rows)
// Applied identically to both the NCDD summary and Defect Coordinates tables
// ============================================================
If(val_hide_status == 1,
	dt << Select Where(:STATUS == "HIGHFLIER" & :CHAMBER == "FLEET");
    dt << Hide and Exclude;
    dt << Clear Select;
	dt_coords << Select Where(:STATUS == "HIGHFLIER" & :CHAMBER == "FLEET");
    dt_coords << Hide and Exclude;
    dt_coords << Clear Select;
,
    If(val_hide_status == 2,
        dt << Select Where(:STATUS == "HIGHFLIER");
        dt << Hide and Exclude;
        dt << Clear Select;
        dt_coords << Select Where(:STATUS == "HIGHFLIER");
        dt_coords << Hide and Exclude;
        dt_coords << Clear Select;
    ,
        If(val_hide_status == 3,
			dt << Select Where(:STATUS == "BASELINE" | :STATUS == "BSL");
            dt << Hide and Exclude;
            dt << Clear Select;
			dt_coords << Select Where(:STATUS == "BASELINE" | :STATUS == "BSL");
            dt_coords << Hide and Exclude;
            dt_coords << Clear Select;
        );
    );
);
// ============================================================
// END HIGHFLIER / BASELINE FILTER
// ============================================================

// Build an explicit _INCLUDE flag per row in dt_coords so the subset
// selection does not rely on hide/exclude row state transfer (unreliable in JMP).
// _INCLUDE=1 means the row passes both the FLEET filter and the status filter.
dt_coords << New Column("_INCLUDE", Numeric, Continuous,
    Set Each Value(
        _fleet_ok = (val_show_fleet == 1 | :CHAMBER != "FLEET");
        _status_ok = If(val_hide_status == 1,
			!(:STATUS == "HIGHFLIER" & :CHAMBER == "FLEET"),
            If(val_hide_status == 2,
                :STATUS != "HIGHFLIER",
                If(val_hide_status == 3,
					:STATUS != "BASELINE" & :STATUS != "BSL",
                    1  // val_hide_status == 4: show all
                )
            )
        );
        _fleet_ok & _status_ok
    )
);

// ============================================================
// DEBUG — verify _INCLUDE counts before subsetting
// ============================================================
Print("=== SUBSET DEBUG ===");
Print("val_show_fleet=" || Char(val_show_fleet) || "  val_hide_status=" || Char(val_hide_status));
Print("dt_coords total rows: " || Char(N Rows(dt_coords)));
dt_coords << Select Where(:CHAMBER == "FLEET");
Print("dt_coords FLEET rows: " || Char(N Row(dt_coords << Get Selected Rows)));
dt_coords << Clear Select;
dt_coords << Select Where(:_INCLUDE == 1);
Print("dt_coords _INCLUDE=1 rows: " || Char(N Row(dt_coords << Get Selected Rows)));
dt_coords << Clear Select;
// ============================================================

// Create subset tables using the explicit _INCLUDE filter.
// ALL DEFECTS gets its own subset too — using dt_coords directly in the
// Bivariate wafermap doesn't honor hide/exclude row states in JMP.
dt_coords << Select Where(:_INCLUDE == 1);
::_dt_coords_all = dt_coords << Subset(
    Selected Rows,
    Output Table("All Coords"),
    Invisible
);
dt_coords << Clear Select;

dt_coords << Select Where(:CLASS == "SMALL_PARTICLE" & :_INCLUDE == 1);
::_dt_coords_smp = dt_coords << Subset(
    Selected Rows,
    Output Table("SMP Coords"),
    Invisible
);
dt_coords << Clear Select;

dt_coords << Select Where(:CLASS == "BEEP" & :_INCLUDE == 1);
::_dt_coords_beep = dt_coords << Subset(
    Selected Rows,
    Output Table("BEEP Coords"),
    Invisible
);
dt_coords << Clear Select;

// Clean up temporary column — not needed downstream.
dt_coords << Delete Columns({"_INCLUDE"});

// ============================================================
// DEBUG — verify FLEET rows are absent from subset tables
// ============================================================
::_dt_coords_all << Select Where(:CHAMBER == "FLEET");
Print("_dt_coords_all rows: " || Char(N Rows(::_dt_coords_all)));
Print("_dt_coords_all FLEET rows (should be 0): " || Char(N Row(::_dt_coords_all << Get Selected Rows)));
::_dt_coords_all << Clear Select;
::_dt_coords_smp << Select Where(:CHAMBER == "FLEET");
Print("_dt_coords_smp rows: " || Char(N Rows(::_dt_coords_smp)));
Print("_dt_coords_smp FLEET rows (should be 0): " || Char(N Row(::_dt_coords_smp << Get Selected Rows)));
::_dt_coords_smp << Clear Select;
::_dt_coords_beep << Select Where(:CHAMBER == "FLEET");
Print("_dt_coords_beep rows: " || Char(N Rows(::_dt_coords_beep)));
Print("_dt_coords_beep FLEET rows (should be 0): " || Char(N Row(::_dt_coords_beep << Get Selected Rows)));
::_dt_coords_beep << Clear Select;
Print("=== SUBSET DEBUG END ===");
// ============================================================

// Set label columns on all four coord tables (LOT + WAFER_ID).
dt_coords         << Set Label Columns(:LOT, :WAFER_ID);
::_dt_coords_all  << Set Label Columns(:LOT, :WAFER_ID);
::_dt_coords_smp  << Set Label Columns(:LOT, :WAFER_ID);
::_dt_coords_beep << Set Label Columns(:LOT, :WAFER_ID);

Apply_Wafermap_Point_Styling = Function({coord_table},
	coord_table << Select Where(:CLASS == "BEEP");
	coord_table << Markers(1);
	coord_table << Clear Select;

	coord_table << Select Where(:CLASS == "SMALL_PARTICLE");
	coord_table << Markers(Dot);
	coord_table << Clear Select;

	If(val_black_wafermap_markers == 1,
		coord_table << Select All Rows;
		coord_table << Colors(Black);
		coord_table << Clear Select;
	);
);

Apply_Wafermap_Point_Styling(dt_coords);
Apply_Wafermap_Point_Styling(::_dt_coords_all);
Apply_Wafermap_Point_Styling(::_dt_coords_smp);
Apply_Wafermap_Point_Styling(::_dt_coords_beep);


// Path to the organized defect image folder used by the integrated pipeline
defect_images_folder = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\Defects\BE\images\defects";

NCDD_win=New Window(selected_member || " - " || window_title,
    lb = V List Box(

        // ---------------------------------------------------------------
		// DEFECT IMAGE FOLDER SHORTCUT — button opens the migrated image folder in Windows Explorer
        H List Box(
            Button Box("Open DefectImages Folder",
                Run Program(
                    Executable("cmd.exe"),
                    Options({"/c", "start", "", defect_images_folder})
                );
            ),
        ),

		//STARTING BY PROD CHART TIME TRENDS -
		myTitle = "ALL PRODUCTS "||filter_str;


		
				

V List Box(		

	///////////////////////////////////////////////////////////////////////////////
	//INFO BOX ////////////////////////////////////////////////////////////////////
	///////////////////////////////////////////////////////////////////////////////	
    dt << FitGroup(

	dt << Distribution(Stack( 1 ),Arrange in Rows( 9 ),	
		Nominal Distribution(Column( :SUBENTITY ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),
		Nominal Distribution(Column( :PILOT_STATUS ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),
		Nominal Distribution(Column( :RECIPE ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),			
		Title("AME"), ,SendToReport(Dispatch({},"AME",OutlineBox,{Close( 1 )})), 
			),
			dt << Distribution(Stack( 1 ),Arrange in Rows( 4 ),
		Nominal Distribution(Column( :STATUS ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),
		Nominal Distribution(Column( :LAYER ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),		
		Nominal Distribution(Column( :PRODUCT ),Frequencies( 0 ),Horizontal Layout( 1 ),Count Axis( 1 ),Vertical( 0 )),
		Title("LOT"),SendToReport(Dispatch({},"LOT",OutlineBox,{Close( 1 )})),
		),
// closes distribution
						SendToReport(Dispatch( {}, "Fit Group", OutlineBox, {Set Title( filter_str ), Close ( 0 ) })), <<{Arrange in Rows( 3 )});,//closes Fit Group
	///////////////////////////////////////////////////////////////////////////////
	//END INFO BOX ////////////////////////////////////////////////////////////////
	///////////////////////////////////////////////////////////////////////////////	
	
	///////////////////////////////////////////////////////////////////////////////
	//SUM TREND AND VAR CHART FIT GROUPS///////////////////////////////////////////
	///////////////////////////////////////////////////////////////////////////////

	H List Box(
	fg_trend_sum= dt << FitGroup(
	
		//needs to make bivs by chart product, here (ALL DEFECTS wafermap is col 2 — before var charts)
		trend_sum=Bivariate(Y( Column( ycol0)),X( Column ( xcol ) ),By( Column ( bycol1 )),
			GroupBy( Column( legendcol1) ), // The column to group by
			Fit Spline(0.1, Standardized, {Report( 0 ), Line Width( 0.1)}),
