trend_row_heights = Associative Array();
var_row_heights = Associative Array();
wmap_row_heights = Associative Array();
row_target_heights = Associative Array();

trend_reports_by_row = Associative Array();
var_reports_by_row = Associative Array();
wmap_reports_by_row = Associative Array();

Build_Row_Height_Key = Function({metric_label, layer_label},
	Trim(metric_label) || "|" || Trim(layer_label)
);

Get_Report_Height = Function({rpt},
	Wait(0);
	_size = rpt << Get Size;
	If(Is List(_size) & N Items(_size) >= 2,
		_size[2],
		.
	)
);

Update_Row_Target_Height = Function({row_key},
	_target = .;
	Try(_th = trend_row_heights[row_key], _th = .);
	If(!Is Missing(_th), _target = _th);
	Try(_vh = var_row_heights[row_key], _vh = .);
	If(!Is Missing(_vh),
		If(Is Missing(_target), _target = _vh, _target = Max(_target, _vh));
	);
	Try(_wh = wmap_row_heights[row_key], _wh = .);
	If(!Is Missing(_wh),
		If(Is Missing(_target), _target = _wh, _target = Max(_target, _wh));
	);
	If(!Is Missing(_target),
		row_target_heights[row_key] = _target;
	);
	_target;
);

Apply_Target_Trend_Report_Height = Function({rpt, metric_label, layer_label},
	_target_key = Build_Row_Height_Key(metric_label, layer_label);
	_target_height = row_target_heights[_target_key];
	If(Is Missing(_target_height),
		_target_height = trend_row_heights[_target_key];
	);
	If(Is Missing(_target_height), Return());

	_current_height = Get_Report_Height(rpt);
	If(Is Missing(_current_height), Return());

	If(_current_height < _target_height,
		_delta_height = _target_height - _current_height;
		Try(rpt << Set Height(_target_height));
		Try(rpt << Append(Spacer Box(Size(1, _delta_height))));
	,
		If(_current_height > _target_height,
			Try(rpt << Set Height(_target_height));
		);
	);
);

Apply_Target_Variability_Report_Height = Function({rpt, metric_label, layer_label},
	_target_key = Build_Row_Height_Key(metric_label, layer_label);
	_target_height = row_target_heights[_target_key];
	If(Is Missing(_target_height),
		_target_height = trend_row_heights[_target_key];
	);
	If(Is Missing(_target_height),
		Return()
	);

	_current_height = Get_Report_Height(rpt);
	If(Is Missing(_current_height),
		Return()
	);

	If(_current_height < _target_height,
		_delta_height = _target_height - _current_height;
		// Keep variability chart geometry stable; align rows by adding only
		// outer vertical padding instead of stretching the data frame.
		Try(rpt << Set Height(_target_height));
		Try(rpt << Append(Spacer Box(Size(1, _delta_height))));
	,
		If(_current_height > _target_height,
			Try(rpt << Set Height(_target_height));
		);
	);
);

Apply_Target_Wafermap_Report_Height = Function({rpt, metric_label, layer_label},
	_target_key = Build_Row_Height_Key(metric_label, layer_label);
	_target_height = row_target_heights[_target_key];
	If(Is Missing(_target_height),
		_target_height = trend_row_heights[_target_key];
	);
	If(Is Missing(_target_height),
		Return()
	);

	_current_height = Get_Report_Height(rpt);
	If(Is Missing(_current_height),
		Return()
	);

	If(_current_height < _target_height,
		_delta_height = _target_height - _current_height;
		// Keep wafermap frame square; add vertical padding outside the frame.
		Try(rpt << Set Height(_target_height));
		Try(rpt << Append(Spacer Box(Size(1, _delta_height))));
	,
		If(_current_height > _target_height,
			Try(rpt << Set Height(_target_height));
		);
	);
);

Align_All_Row_Heights = Function({},
	Try(_row_keys = row_target_heights << Get Keys, _row_keys = {});
	For(_i = 1, _i <= N Items(_row_keys), _i++,
		_row_key = _row_keys[_i];
		_metric_label = Word(1, _row_key, "|");
		_layer_label = Word(2, _row_key, "|");

		Try(_tr = trend_reports_by_row[_row_key], _tr = .);
		Try(_vr = var_reports_by_row[_row_key], _vr = .);
		Try(_wr = wmap_reports_by_row[_row_key], _wr = .);

		Try(If(!Is Missing(_tr), Apply_Target_Trend_Report_Height(_tr, _metric_label, _layer_label)));
		Try(If(!Is Missing(_vr), Apply_Target_Variability_Report_Height(_vr, _metric_label, _layer_label)));
		Try(If(!Is Missing(_wr), Apply_Target_Wafermap_Report_Height(_wr, _metric_label, _layer_label)));

		Try(If(!Is Missing(_tr), trend_row_heights[_row_key] = Get_Report_Height(_tr)));
		Try(If(!Is Missing(_vr), var_row_heights[_row_key] = Get_Report_Height(_vr)));
		Try(If(!Is Missing(_wr), wmap_row_heights[_row_key] = Get_Report_Height(_wr)));
		Update_Row_Target_Height(_row_key);
	);
);



Format_Trend_Charts = Function({trend_chart_object},

	Treports = trend_chart_object << Report;
	//(reports << XPath("//OutlineBox[contains(., 'Smoothing Spline Fit')]")) << Visibility("Collapse");
	j=0; Show(N Items(Treports));
	For Each( {rpt}, Treports,
		j=j+1;
		current_by_value = rpt << Get Title;

		//Print(current_by_value,bycol,title);
		//fbTitles 		= {};			
		//preorder(rpt[1]); 			Print("\!n", fbTitles);
		rpt[1][Frame Box(1)]  << Row Legend(Column ( legendcol1 ),Color( 0 ),Color Theme( "" ),Marker( 0 ),Marker Theme( "" ),Continuous Scale( 0 ),Reverse Scale( 0 ),Excluded Rows( 0 ));
		//rpt[1][Frame Box(1)] << {Marker Size(3), Marker Drawing Mode("Outlined"),Fill Selection Mode("Selected Outlined")};
		rpt[1][Frame Box(1)] << {Marker Drawing Mode("Outlined")};
		
		// Find positions of "of " and " By"
		of_pos = Contains(current_by_value, "of ");
		by_pos = Contains(current_by_value, " By ");

		// Extract Y column name between "of " and " By"
		y_col_name = Substr(current_by_value, of_pos + 3, by_pos - of_pos - 3);
		layer_value = Word(-1, current_by_value, "=");
		y_col_display = Substitute(y_col_name, "_", " ");
		new_title = y_col_display || " " || layer_value;
		
		rpt << Set Title( new_title );	

	rpt[AxisBox(1)] << Axis Settings({Min(ymin), Max(ymax), Inc(inc),Minor Ticks(0)});
		
	axisbox = rpt[axis box( 1 )]; axisbox << Show Major Grid( 1 );
	axisbox = rpt[axis box( 1 )]; axisbox << Show Minor Grid( 1 );
	axisbox = rpt[axis box( 2 )]; axisbox << Show Major Grid( 1 );
	axisbox = rpt[axis box( 2 )]; axisbox << Show Minor Grid( 1 );

	Try(rpt[BorderBox(3)] << Visibility("Collapse"));

	rpt[FrameBox(1)]  <<Set Height( 330 ); rpt[FrameBox(1)]  <<Set Width( 500 );
	_trend_row_key = Build_Row_Height_Key(y_col_display, layer_value);
	trend_row_heights[_trend_row_key] = Get_Report_Height(rpt);
	trend_reports_by_row[_trend_row_key] = rpt;
	Update_Row_Target_Height(_trend_row_key);

	// rqt[BorderBox(1)] << Show Window
	);//end for each	
);	
Format_Trend_Charts(trend_sum);
Format_Trend_Charts(trend_smp);
Format_Trend_Charts(trend_beep);
	


Format_Variability_Charts = Function({var_chart_object, ycol_label, top_level_group_label},
			
	Vreports=var_chart_object << Report;
	//(reports << XPath("//OutlineBox[contains(., 'Smoothing Spline Fit')]")) << Visibility("Collapse");
	j=0; Show(N Items(Vreports));
	For Each( {rpt}, Vreports,
		j=j+1;
		current_by_value = rpt << Get Title;
			

		//Print(current_by_value,bycol,title);
		//fbTitles 		= {};			//preorder(rpt[1]); 			Print("\!n", fbTitles);
		//rpt[1][Frame Box(1)]  << Row Legend(Column ( legendcol1 ),Color( 0 ),Color Theme( "" ),Marker( 0 ),Marker Theme( "" ),Continuous Scale( 0 ),Reverse Scale( 0 ),Excluded Rows( 0 ));
	//	rpt[1][Frame Box(1)]  << Row Legend(Column ( legendcol2 ),Color( 0 ),Color Theme( "" ),Marker( 0 ),Marker Theme( "" ),Continuous Scale( 0 ),Reverse Scale( 0 ),Excluded Rows( 0 ));
		rpt[1][Frame Box(1)] << {Marker Drawing Mode("Outlined")};

		layer_value = "";
		If(Contains(current_by_value, "=") > 0,
			layer_value = Trim(Word(-1, current_by_value, "="));
		);

		rpt << Set Title( "VARIABILITY BY " || top_level_group_label );		
		
			
			//reports[1][OutlineBox(1)] << Set Title ("STLT MEAN by SUBENTITY");
			rpt[1][OutlineBox(1)] << Set Title ("ANALYSIS");
			If(layer_value == "",
				rpt[1][OutlineBox(2)] << Set Title (ycol_label);
			,
				rpt[1][OutlineBox(2)] << Set Title (ycol_label || " " || layer_value);
			);
			//rpt[1][OutlineBox(2)] << Set Title Wrap(0);
			rpt[1][TextBox(2)] << Set Text("");
			//reports[1][FrameBox(1)] << YAxis( Min( 20 ), Max( 40 ));
			axisbox = rpt[1][axis box( 1 )]; axisbox << Show Major Grid( 1 );
			axisbox = rpt[1][axis box( 1 )]; axisbox << Show Minor Grid( 1 );
			axisbox = rpt[1][axis box( 2 )]; axisbox << Show Major Grid( 1 );
			axisbox = rpt[1][axis box( 2 )]; axisbox << Show Minor Grid( 1 );

			
			rpt[AxisBox(1)] << Axis Settings({Min(ymin), Max(ymax), Inc(inc),Minor Ticks(0)});

			axisbox = rpt[axis box( 1 )]; axisbox << Show Major Grid( 1 );
			axisbox = rpt[axis box( 1 )]; axisbox << Show Minor Grid( 1 );
			axisbox = rpt[axis box( 2 )]; axisbox << Show Major Grid( 1 );
			axisbox = rpt[axis box( 2 )]; axisbox << Show Minor Grid( 1 );
		
			mySegs=rpt[FrameBox(1)]<< find segs; // get all display elements
				Filter Each({seg},(mySegs), (seg<< class name)=="BoxPlotSeg") << Set Line Color("Black");
			mySegs=rpt[FrameBox(1)]<< find segs; // get all display elements
				Filter Each({seg},(mySegs), (seg<< class name)=="BoxPlotSeg") << Set Line Color("Black");
				
			varchart_groups=rpt[AxisBox(2)] << Get Max;
			varchart_width=varchart_groups*varchart_group_width;
			framebox=rpt[FrameBox(1)];
			framebox   <<Set Width( varchart_width );
			framebox << Get Size;
			framebox <<Set Height( 230 );
			_var_row_key = Build_Row_Height_Key(ycol_label, layer_value);
			var_row_heights[_var_row_key] = Get_Report_Height(rpt);
			var_reports_by_row[_var_row_key] = rpt;
			Update_Row_Target_Height(_var_row_key);

			
			varchart_axisbox=rpt[AxisBox(2)];			
			varchart_axisbox <<Set Height( 80 );

	);//end for each	
); //close function
Format_Variability_Charts(var_sum,  "SUM NCDD", bycol1);
Format_Variability_Charts(var_smp,  "SMP NCDD", bycol1);
Format_Variability_Charts(var_beep, "BEEP NCDD", bycol1);
Format_Variability_Charts(var_sum_prod,  "SUM NCDD", vcol2);
Format_Variability_Charts(var_smp_prod,  "SMP NCDD", vcol2);
Format_Variability_Charts(var_beep_prod, "BEEP NCDD", vcol2);


///////////////////////////////////////////////////////////////////////////////
// FORMAT WAFERMAP
///////////////////////////////////////////////////////////////////////////////
Format_Wafermap = Function({wmap_obj, metric_label},
	Wmreports = wmap_obj << Report;
	If(Is List(Wmreports),
		_wm_report_list = Wmreports;
	,
		_wm_report_list = {Wmreports};
	);
	For Each({rpt}, _wm_report_list,
		layer_val = Word(-1, rpt << Get Title, "=");
		rpt << Set Title("WAFERMAP " || Trim(layer_val));

		rpt[1][FrameBox(1)] << Frame Size(280, 280);
		rpt[1][AxisBox(1)] << Axis Settings({Min(-165), Max(165), Inc(50), Minor Ticks(0)});
		rpt[1][AxisBox(2)] << Axis Settings({Min(-165), Max(165), Inc(50), Minor Ticks(0)});
		rpt[1][AxisBox(1)] << {Show Major Grid(1), Show Minor Grid(1)};
		rpt[1][AxisBox(2)] << {Show Major Grid(1), Show Minor Grid(1)};

		// Wafer boundary circle (150 mm radius)
		rpt[1][FrameBox(1)] << Add Graphics Script(2, Description("WaferCircle"),
			Pen Color("Dark Gray");
			Pen Size(2);
			Oval(-150, -150, 150, 150);
		);

		If(val_black_wafermap_markers == 0,
			// Legend shows CLASS labels for verification; Color(0)/Marker(0) prevent
			// overwriting the pre-set CHAMBER row states on dt_coords.
			rpt[1][FrameBox(1)] << Row Legend(:CLASS,
				Color(0), Color Theme(""),
				Marker(0), Marker Theme(""),
				Continuous Scale(0), Reverse Scale(0), Excluded Rows(0)
			);
		);
		rpt[1][FrameBox(1)] << {Marker Drawing Mode("Normal")};

		// Square frame matching trend chart height (330×330)
		rpt[1][FrameBox(1)] << Frame Size(330, 330);

		// Remove fit summary text box
		rpt[1][TextBox(1)] << Set Text("");
		_wm_row_key = Build_Row_Height_Key(metric_label, layer_val);
		wmap_row_heights[_wm_row_key] = Get_Report_Height(rpt);
		wmap_reports_by_row[_wm_row_key] = rpt;
		Update_Row_Target_Height(_wm_row_key);
	);
);
Format_Wafermap(wmap_all, "SUM NCDD");
Format_Wafermap(wmap_smp, "SMP NCDD");
Format_Wafermap(wmap_beep, "BEEP NCDD");
Align_All_Row_Heights();


// Maximize the window after creation
NCDD_win << Maximize Window;

dt << Select Where(:CHAMBER != "FLEET");



// Usage tracking - final version
log_path = "\\orshfs.intel.com\ORAnalysis$\1276_MAODATA\Config\etch\AME\tbatson\backups\BEEP_SMP_LAYER_CHAMBER_log.txt";

track_usage = Function({},
    Try(
        timestamp = Char(Today());
        log_entry = timestamp || " - Script usage" || "\n";
        
        // Check if file exists to append or create
        If(File Exists(log_path),
            current_content = Load Text File(log_path);
            new_content = current_content || log_entry;
            Save Text File(log_path, new_content);
        ,
            Save Text File(log_path, log_entry);
        );
    ,
        // Silent fail if there are any issues
    );
);

// Call this at the beginning of your main script
track_usage();

// ============================================================
// BIDIRECTIONAL SELECTION SYNC — NCDD <-> Defect Coordinates
//
// Uses Make Row State Handler (native JMP API) which fires on
// ALL row state changes: chart point clicks, variability chart
// clicks, data-grid row clicks, and JSL SelectRows calls.
// Set Selection Handler only fires on data-grid clicks — that's
// why chart selections were not propagating before.
//
// Propagation uses ORIGINAL_ROW_NUMBER (built at startup above)
// so coord rows are selected with a single O(1) Contains call.
// ============================================================

::_dt_ncdd        = dt;
::_dt_coords      = dt_coords;
::_dt_coords_all  = ::_dt_coords_all;   // already set above
::_dt_coords_smp  = ::_dt_coords_smp;   // already set above
::_dt_coords_beep = ::_dt_coords_beep;  // already set above
::_prev_sel       = [];

::_rsh = ::_dt_ncdd << Make Row State Handler(
    Function({rows}, {Default Local},
        sel = ::_dt_ncdd << Get Selected Rows;

        // Delta guard — skip if selection hasn't actually changed
        If(
            N Row(sel) == N Row(::_prev_sel) &
            (N Row(sel) == 0 | All(sel == ::_prev_sel)),
            Return();
        );
        ::_prev_sel = sel;

        Print("MakeRowStateHandler: " || Char(N Row(sel)) || " NCDD rows selected");
        If(N Row(sel) > 0,
            // Build a list of integers from the selected-row matrix.
            // Contains() requires a List {}, not a matrix [], to match
            // the numeric column values stored as floats in dt_coords.
            _sel_list = {};
            For(_i = 1, _i <= N Row(sel), _i++,
                Insert Into(_sel_list, sel[_i]);
            );
            ::_dt_coords << Select Where(
                Contains(_sel_list, Round(Column(::_dt_coords,"ORIGINAL_ROW_NUMBER")[Row()], 0))
            );
            ::_dt_coords_all << Select Where(
                Contains(_sel_list, Round(Column(::_dt_coords_all,"ORIGINAL_ROW_NUMBER")[Row()], 0))
            );
            ::_dt_coords_smp << Select Where(
                Contains(_sel_list, Round(Column(::_dt_coords_smp,"ORIGINAL_ROW_NUMBER")[Row()], 0))
            );
            ::_dt_coords_beep << Select Where(
                Contains(_sel_list, Round(Column(::_dt_coords_beep,"ORIGINAL_ROW_NUMBER")[Row()], 0))
            );
            Print("  -> " || Char(N Rows(::_dt_coords_all << Get Selected Rows)) || " coord rows");
        ,
            ::_dt_coords      << Clear Select;
            ::_dt_coords_all  << Clear Select;
            ::_dt_coords_smp  << Clear Select;
            ::_dt_coords_beep << Clear Select;
        );
    )
);

Print("MakeRowStateHandler installed on: " || (::_dt_ncdd << Get Name));

// Immediately propagate the existing non-FLEET selection into dt_coords
_init_sel = ::_dt_ncdd << Get Selected Rows;
If(N Row(_init_sel) > 0,
    _init_list = {};
    For(_i = 1, _i <= N Row(_init_sel), _i++, Insert Into(_init_list, _init_sel[_i]));
    ::_dt_coords << Select Where(
        Contains(_init_list, Round(Column(::_dt_coords,"ORIGINAL_ROW_NUMBER")[Row()], 0))
    );
    ::_dt_coords_all << Select Where(
        Contains(_init_list, Round(Column(::_dt_coords_all,"ORIGINAL_ROW_NUMBER")[Row()], 0))
    );
    ::_dt_coords_smp << Select Where(
        Contains(_init_list, Round(Column(::_dt_coords_smp,"ORIGINAL_ROW_NUMBER")[Row()], 0))
    );
    ::_dt_coords_beep << Select Where(
        Contains(_init_list, Round(Column(::_dt_coords_beep,"ORIGINAL_ROW_NUMBER")[Row()], 0))
    );
    Print("Initial sync: " || Char(N Rows(::_dt_coords_all << Get Selected Rows)) || " coord rows selected");
);


