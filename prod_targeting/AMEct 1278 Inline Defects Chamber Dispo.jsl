					path = path_extended;
					coords_path = coords_path_extended;
					selected_source_name = "Full integrated";
				,
					If(val_source_index == 3,
						path = path_extended;
						coords_path = coords_path_extended;
						selected_source_name = "YYMM lookback (" || Char(val_yymm_lookback_periods) || " periods)";
					,
						path = path_60day;
						coords_path = coords_path_60day;
						selected_source_name = "Most recent 60 days";
					);
				,
					path = path_60day;
					coords_path = coords_path_60day;
					selected_source_name = "Most recent 60 days";
				);

                // Resolve chamber override — SUBENTITY_TB is always top priority.
                // Accepts a comma-separated list, e.g. "AME409_PM1,AME411_PM4,AME427_PM3"
                SUBENTITY_STR = Trim(SUBENTITY_TB << Get Text());
                If(SUBENTITY_STR != "",
                    // Parse comma-separated entries into chamber_list
                    chamber_list = Words(SUBENTITY_STR, ",");
                    // Trim whitespace from each entry
                    For(i = 1, i <= N Items(chamber_list), i++,
                        chamber_list[i] = Trim(chamber_list[i]);
                    );
                    selected_member = "CUSTOM: " || SUBENTITY_STR;
                ,
