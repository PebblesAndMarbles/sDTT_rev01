result = New Window( "NCDD Report Options", <<Modal, <<Return Result,
    V List Box(
        Lineup Box(N Col(1),
			Panel Box("CSV SOURCE",
				rbSource = Radio Box(
					{"Most recent 60 days CSV + coordinates",
					 "Full integrated CSV + coordinates",
					 "YYMM lookback on full CSVs"}
				),
				H List Box(
					Text Box("YYMM periods:"),
					yymmLookbackTB = Text Edit Box("12", <<Set Width(40))
				)
			),
            Panel Box("SELECT TEAM MEMBER",
                rbChamber = Radio Box( {"Trey", "Kayden", "Chang", "Adi", "Travis", "Tyler", "Mathius", "Sashank", "William", "Minog"} ),
            ),
            Panel Box("SINGLE CHAMBER OVERRIDE  (supersedes team member selection)",
                Lineup Box(N Col(7),
                    Text Box( "AME4" ), ENTITY_TB = Text Edit Box( "", <<Set Width( 25 ) ),
                    Text Box( "_PM" ), PM_TB = Text Edit Box( "", <<Set Width( 12 ) ),
                    Spacer Box(Size(10, 10)),
                    Text Box( "  — or full SUBENTITY:" ), SUBENTITY_TB = Text Edit Box( "", <<Set Width( 100 ) ),
                ),
            ),
            Panel Box("OPTIONS",
                cb_close_reports_and_windows = Check Box( "Close Reports & Windows" ),
                cb_show_fleet = Check Box( "Show FLEET Coordinates" ),
				cb_black_wafermap_markers = Check Box( "Black Wafermap Markers" ),
            ),
            Panel Box("HIGHFLIER / BASELINE FILTER",
                rbHideStatus = Radio Box(
                    {"Hide Highfliers NOT in chamber list",
                     "Hide ALL Highfliers",
                     "Hide BASELINE rows",
                     "Hide / Exclude nothing (show all rows)"}
                ),
            ),
            Button Box( "OK",
                val_cb_close_reports_and_windows = cb_close_reports_and_windows << Get;
                val_show_fleet = cb_show_fleet << Get;
				val_black_wafermap_markers = cb_black_wafermap_markers << Get;
                val_hide_status = rbHideStatus << Get;
                val_chamber_index = rbChamber << Get;
				val_source_index = rbSource << Get;
				val_yymm_lookback_periods = Parse_Lookback_Periods(yymmLookbackTB << Get Text, 12);
