                        CHAMBER_STR = "AME4" || ENTITY_STR || "_PM" || PM_STR;
                        chamber_list = {};
                        Insert Into(chamber_list, CHAMBER_STR);
                        selected_member = "CUSTOM: " || CHAMBER_STR;
                    ,
                        // Fallback: radio box team member selection
                        chamber_list = chamber_data[val_chamber_index][2];
                        selected_member = chamber_data[val_chamber_index][1];
                    );
